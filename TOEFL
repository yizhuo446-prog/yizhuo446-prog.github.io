        <h1>📊 主题掌握度</h1>
        <div class="card" id="theme-stats-container"><p class="text-muted">暂无数据</p></div>
        <button class="btn btn-outline" onclick="backToMenu()">⬅ 返回</button>
    </div>
</div>
<div id="toast" class="toast"></div>

