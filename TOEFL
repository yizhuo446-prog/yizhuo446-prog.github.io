</head>
<body>
<div class="container" id="app">
    <!-- 登录 -->
    <div id="page-login" class="page active">
        <div class="text-center" style="padding: 30px 0 10px;">
            <h1 style="justify-content:center;">🧭 词汇远征队</h1>
            <p style="color: #64748b; margin: 6px 0 24px;">40关 · 800托福核心词 · 主题闯关</p>
            <div class="card" style="max-width: 360px; margin: 0 auto;">
                <label style="font-weight:600;">账号 (任意昵称)</label>
                <input id="login-username" type="text" placeholder="输入你的名字" value="探险家"
                       style="width:100%; padding:14px 16px; border-radius:40px; border:2px solid #e2e8f0; margin:10px 0 18px; font-size:1rem;" />
                <button class="btn btn-primary" style="width:100%; justify-content:center;" onclick="login()">🚀 出发</button>
                <p style="font-size:0.7rem; color:#94a3b8; margin-top:12px;">数据保存在本地浏览器</p>
            </div>
        </div>
    </div>

    <!-- 主菜单 -->
    <div id="page-menu" class="page">
        <div class="flex-between">
            <h1>🧭 远征 <small id="menu-username"></small></h1>
            <div style="display:flex; gap:6px; flex-wrap:wrap;">
                <button class="btn btn-outline" onclick="showWrongBook()">📕 错题</button>
                <button class="btn btn-outline" onclick="showThemeStats()">📊 主题</button>
                <button class="btn btn-outline" onclick="resetAll()" style="color:#ef4444;">🔄 重置</button>
            </div>
        </div>
        <div class="card">
            <div class="stats-bar">
                <span>🏆 总分: <strong id="menu-total-score">0</strong></span>
                <span>✅ 正确: <strong id="menu-total-correct">0</strong></span>
                <span>❌ 错误: <strong id="menu-total-wrong">0</strong></span>
                <span>📌 进度: <strong id="menu-progress">0/40</strong></span>
            </div>
        </div>
        <div class="card" style="padding:12px;">
            <div style="font-weight:600; margin-bottom:8px; font-size:0.9rem; color:#475569;">🗺️ 点击已解锁关卡开始 (绿=通关, 蓝=可挑战)</div>
            <div class="scroll-levels">
                <div class="grid-levels" id="level-grid"></div>
            </div>
        </div>
        <div class="text-center mt-2 text-muted" style="font-size:0.8rem;">每关20词 · 5条命 · 答错扣命</div>
    </div>

    <!-- 游戏界面 -->
    <div id="page-game" class="page">
        <div class="flex-between">
            <span><span id="game-level-label">第 1 关</span> · <span id="game-stage">1</span>/20</span>
            <span class="lives" id="game-lives-display"></span>
            <span>💯 <span id="game-score">0</span></span>
        </div>
        <div class="card" style="margin-top:8px;">
            <div class="word-display" id="game-word">—</div>
            <div class="pos-theme" id="game-pos-theme">📚 主题 · General</div>
            <div class="options" id="game-options">
                <button class="option-btn" data-index="0">-</button>
                <button class="option-btn" data-index="1">-</button>
                <button class="option-btn" data-index="2">-</button>
                <button class="option-btn" data-index="3">-</button>
            </div>
            <div id="game-feedback" style="margin-top:14px; font-weight:500; text-align:center; min-height:28px;"></div>
            <div style="margin-top:12px; display:flex; gap:10px; justify-content:center; flex-wrap:wrap;">
                <button class="btn btn-outline" onclick="exitGame()">🚪 退出</button>
                <button class="btn btn-outline" id="btn-next" style="display:none;" onclick="nextQuestion()">⏩ 下一题</button>
            </div>
        </div>
    </div>

    <!-- 错题本 -->
    <div id="page-wrongbook" class="page">
        <h1>📕 错题本</h1>
        <div class="card" id="wrong-list-container"><p class="text-muted">暂无错题</p></div>
        <button class="btn btn-outline" onclick="backToMenu()">⬅ 返回</button>
    </div>

    <!-- 主题统计 -->
