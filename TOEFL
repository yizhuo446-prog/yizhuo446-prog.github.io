// 2. 关卡配置 (40关, 每关20词)
// ============================================================
const LEVEL_THEMES = {
  1:'General',2:'General',3:'General',4:'General',5:'General',
  6:'Environment',7:'Environment',8:'Environment',9:'Environment',10:'Environment',
  11:'Biology',12:'Biology',13:'Biology',14:'Biology',15:'Biology',
  16:'Geology',17:'Geology',18:'Geology',19:'Geology',20:'Geology',
  21:'History',22:'History',23:'History',24:'History',25:'History',
  26:'Business',27:'Business',28:'Business',29:'Business',30:'Business',
  31:'Psychology',32:'Psychology',33:'Psychology',34:'Psychology',35:'Psychology',
  36:'Advanced',37:'Advanced',38:'Advanced',39:'Advanced',40:'Advanced'
};

function getLevelWords(level) {
  const theme = LEVEL_THEMES[level];
  const pool = WORD_POOLS[theme] || [];
  const start = ((level - 1) % 5) * 20;
  return pool.slice(start, start + 20);
}

// ============================================================
// 3. 游戏数据管理
// ============================================================
function defaultData(username) {
  const levels = {};
  for (let i = 1; i <= 40; i++) {
    levels[i] = { unlocked: (i === 1), completed: false, perfect: false, currentStage: 0, lives: 5, score: 0, wrongWords: [] };
  }
  return { username, totalScore: 0, totalCorrect: 0, totalWrong: 0, levels, themeStats: {} };
}

let data = null, currentLevel = 1, answering = false;

function loadData(username) {
  const raw = localStorage.getItem('vocabExpedition_' + username);
  if (raw) {
    try { data = JSON.parse(raw); if (!data.levels || !data.levels[1]) data = defaultData(username); }
    catch (e) { data = defaultData(username); }
  } else { data = defaultData(username); }
  saveData(); return data;
}
function saveData() { if (data) localStorage.setItem('vocabExpedition_' + data.username, JSON.stringify(data)); }

function getAllWords() {
  let all = [];
  for (const key in WORD_POOLS) all = all.concat(WORD_POOLS[key]);
  return all;
}

function getDistractors(correctChinese, excludeWord) {
  const pool = getAllWords().filter(w => w.c !== correctChinese && w.w !== excludeWord);
  const shuffled = pool.sort(() => Math.random() - 0.5);
  return shuffled.slice(0, 3).map(w => w.c);
}

// ============================================================
// 4. UI 导航 & Toast
// ============================================================
function showPage(id) { document.querySelectorAll('.page').forEach(p => p.classList.remove('active')); document.getElementById(id).classList.add('active'); }
function backToMenu() { showPage('page-menu'); renderMenu(); }
function showToast(msg, dur=2000) { const t=document.getElementById('toast'); t.textContent=msg; t.classList.add('show'); clearTimeout(t._timer); t._timer=setTimeout(()=>t.classList.remove('show'), dur); }

// ============================================================
// 5. 登录
// ============================================================
function login() {
  const name = document.getElementById('login-username').value.trim() || '探险家';
  loadData(name);
  document.getElementById('menu-username').textContent = '👤 ' + data.username;
  renderMenu();
  showPage('page-menu');
  showToast('欢迎回来，' + data.username + '！');
}

// ============================================================
// 6. 渲染主菜单 (40关网格)
// ============================================================
function renderMenu() {
  if (!data) return;
  document.getElementById('menu-username').textContent = '👤 ' + data.username;
  document.getElementById('menu-total-score').textContent = data.totalScore;
  document.getElementById('menu-total-correct').textContent = data.totalCorrect;
  document.getElementById('menu-total-wrong').textContent = data.totalWrong;
  let completedCount = 0;
  for (let i=1; i<=40; i++) if (data.levels[i].completed) completedCount++;
  document.getElementById('menu-progress').textContent = `${completedCount}/40`;

  const grid = document.getElementById('level-grid');
  grid.innerHTML = '';
  for (let i = 1; i <= 40; i++) {
    const info = data.levels[i];
    const node = document.createElement('div');
    node.className = 'level-node';
    if (!info.unlocked) { node.classList.add('locked'); node.innerHTML = `${i}<span class="badge">🔒</span>`; }
    else if (info.completed) {
      node.classList.add('completed');
      node.innerHTML = `${i}<span class="badge">${info.perfect ? '⭐' : '✅'}</span>`;
      node.onclick = () => startLevel(i);
    } else {
      node.classList.add('unlocked');
      node.innerHTML = `${i}<span class="badge">▶</span>`;
      node.onclick = () => startLevel(i);
    }
    grid.appendChild(node);
  }
}

// ============================================================
// 7. 游戏核心逻辑
// ============================================================
function startLevel(level) {
  if (!data.levels[level].unlocked) { showToast('该关未解锁！'); return; }
  currentLevel = level;
  const info = data.levels[level];
  if (info.completed) {
    if (!confirm('已通关，是否重置本关重新挑战？')) return;
    info.completed = false; info.perfect = false; info.currentStage = 0; info.lives = 5; info.score = 0; info.wrongWords = [];
    saveData();
  }
  if (info.lives <= 0) info.lives = 5;
  renderGame();
  showPage('page-game');
}

function renderGame() {
  const info = data.levels[currentLevel];
  const words = getLevelWords(currentLevel);
  const stage = info.currentStage;
  document.getElementById('game-level-label').textContent = `第 ${currentLevel} 关`;
  document.getElementById('game-stage').textContent = Math.min(stage + 1, words.length);
  document.getElementById('game-score').textContent = info.score;

  const livesDiv = document.getElementById('game-lives-display');
  livesDiv.innerHTML = '';
  for (let i=0; i<5; i++) { const s=document.createElement('span'); s.textContent = i < info.lives ? '❤️' : '🖤'; livesDiv.appendChild(s); }

  if (stage >= words.length) { completeLevel(); return; }
  const wordObj = words[stage];
  if (!wordObj) { completeLevel(); return; }

  document.getElementById('game-word').textContent = wordObj.w;
  document.getElementById('game-pos-theme').textContent = `📚 ${LEVEL_THEMES[currentLevel]} · 第 ${stage+1}/20 题`;

  const correct = wordObj.c;
  const distractors = getDistractors(correct, wordObj.w);
  const options = [correct, ...distractors].sort(() => Math.random() - 0.5);
  const btns = document.querySelectorAll('.option-btn');
  btns.forEach((btn, idx) => {
    btn.textContent = options[idx] || '—';
    btn.className = 'option-btn';
    btn.disabled = false;
    btn.dataset.correct = (options[idx] === correct) ? 'true' : 'false';
  });
  document.getElementById('game-feedback').textContent = '';
  document.getElementById('btn-next').style.display = 'none';
  answering = false;
}

function selectOption(e) {
  const btn = e.currentTarget;
  if (answering || btn.disabled) return;
  answering = true;
  const isCorrect = btn.dataset.correct === 'true';
  const info = data.levels[currentLevel];
  const words = getLevelWords(currentLevel);
  const stage = info.currentStage;
  const wordObj = words[stage];

  document.querySelectorAll('.option-btn').forEach(b => b.disabled = true);
  if (isCorrect) {
    btn.classList.add('correct');
    info.score += 10; data.totalScore += 10; data.totalCorrect += 1;
    document.getElementById('game-feedback').textContent = '✅ 正确！ +10分';
    updateThemeStats(LEVEL_THEMES[currentLevel], true);
  } else {
    btn.classList.add('wrong');
    document.querySelectorAll('.option-btn').forEach(b => { if (b.dataset.correct === 'true') b.classList.add('correct'); });
    info.lives -= 1; data.totalWrong += 1;
    info.wrongWords.push({ word: wordObj.w, chinese: wordObj.c, theme: LEVEL_THEMES[currentLevel] });
    document.getElementById('game-feedback').textContent = `❌ 错误！ 正确答案: “${wordObj.c}”`;
    updateThemeStats(LEVEL_THEMES[currentLevel], false);
  }
  document.getElementById('game-score').textContent = info.score;

  if (info.lives <= 0) {
    document.getElementById('game-feedback').textContent += ' 💀 生命耗尽！';
    document.getElementById('btn-next').style.display = 'none';
    const p = document.getElementById('game-feedback').parentNode;
    let retry = p.querySelector('.retry-btn');
    if (!retry) { retry = document.createElement('button'); retry.className = 'btn btn-danger retry-btn'; retry.textContent = '🔁 重试本关'; retry.onclick = ()=>{ resetLevel(currentLevel); startLevel(currentLevel); }; p.appendChild(retry); }
    saveData(); return;
  }

  if (stage + 1 >= words.length) {
    document.getElementById('btn-next').style.display = 'none';
    setTimeout(() => completeLevel(), 700);
  } else {
    document.getElementById('btn-next').style.display = 'inline-block';
  }
  saveData();
}

function nextQuestion() {
  const info = data.levels[currentLevel];
  info.currentStage += 1;
  saveData();
  renderGame();
}

function completeLevel() {
  const info = data.levels[currentLevel];
  if (info.completed) return;
  info.completed = true;
  info.perfect = (info.lives === 5 && info.wrongWords.length === 0);
  if (currentLevel < 40) data.levels[currentLevel + 1].unlocked = true;
  saveData();
  showToast(`🎉 第 ${currentLevel} 关通关！${info.perfect ? ' ⭐完美！' : ''}`, 2500);
  document.getElementById('game-feedback').textContent = `🎉 通关！ ${info.perfect ? '⭐完美评价！' : ''}`;
  document.getElementById('btn-next').style.display = 'none';
  const p = document.getElementById('game-feedback').parentNode;
  let backBtn = p.querySelector('.back-btn');
  if (!backBtn) { backBtn = document.createElement('button'); backBtn.className = 'btn btn-primary back-btn'; backBtn.textContent = '🏠 返回菜单'; backBtn.onclick = backToMenu; p.appendChild(backBtn); }
  renderMenu();
}

// ============================================================
// 8. 主题统计 & 错题本
// ============================================================
function updateThemeStats(theme, correct) {
  if (!data.themeStats[theme]) data.themeStats[theme] = { correct: 0, total: 0 };
  data.themeStats[theme].total += 1;
  if (correct) data.themeStats[theme].correct += 1;
  saveData();
}

function showThemeStats() {
  const c = document.getElementById('theme-stats-container');
  c.innerHTML = '';
  const stats = data.themeStats;
  const keys = Object.keys(stats);
  if (keys.length === 0) { c.innerHTML = '<p class="text-muted">暂无数据</p>'; }
  else {
    keys.forEach(k => {
      const s = stats[k]; const pct = s.total>0 ? Math.round((s.correct/s.total)*100) : 0;
      const div = document.createElement('div'); div.style.cssText = 'display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #f1f5f9;';
      div.innerHTML = `<span><span class="theme-badge">${k}</span></span><span>${s.correct}/${s.total} (${pct}%)</span>`;
      c.appendChild(div);
    });
  }
  showPage('page-theme');
}

function showWrongBook() {
  const c = document.getElementById('wrong-list-container');
  c.innerHTML = '';
  let all = [];
  for (let i=1; i<=40; i++) {
    (data.levels[i].wrongWords || []).forEach(w => all.push({...w, level:i}));
  }
  if (all.length === 0) { c.innerHTML = '<p class="text-muted">暂无错题</p>'; }
  else {
    all.forEach(w => {
      const div = document.createElement('div'); div.className = 'wrong-item';
      div.innerHTML = `<span><strong>${w.word}</strong> — ${w.chinese}</span><span class="theme-badge">Lv.${w.level} · ${w.theme}</span>`;
      c.appendChild(div);
    });
  }
  showPage('page-wrongbook');
}

// ============================================================
// 9. 重置功能
// ============================================================
function resetLevel(level) {
  if (!confirm(`重置第 ${level} 关进度？`)) return;
  const info = data.levels[level];
  info.completed = false; info.perfect = false; info.currentStage = 0; info.lives = 5; info.score = 0; info.wrongWords = [];
  saveData(); renderMenu(); showToast('已重置');
}
function resetAll() {
  if (!confirm('⚠️ 重置全部数据？不可撤销！')) return;
  const name = data.username;
  localStorage.removeItem('vocabExpedition_' + name);
  loadData(name);
  renderMenu();
  showToast('已重置全部');
}
function exitGame() {
  if (confirm('退出游戏？进度已保存。')) backToMenu();
}

// ============================================================
// 10. 初始化
// ============================================================
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.option-btn').forEach(b => b.addEventListener('click', selectOption));
  document.getElementById('login-username').addEventListener('keypress', (e) => { if (e.key === 'Enter') login(); });
});
window.login = login; window.startLevel = startLevel; window.renderMenu = renderMenu; window.backToMenu = backToMenu;
window.showWrongBook = showWrongBook; window.showThemeStats = showThemeStats; window.resetLevel = resetLevel; window.resetAll = resetAll;
window.exitGame = exitGame; window.nextQuestion = nextQuestion; window.selectOption = selectOption;
</script>
</body>
</html>
