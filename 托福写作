<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>托福写作评分系统 · 6分制</title>
    <!-- 使用 Font Awesome 图标库 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        /* ===== 全局重置 & 主题 ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #f6f9fc;
            color: #1a2b3c;
            padding: 2rem 1.5rem;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: flex-start;
        }

        .app-container {
            max-width: 1100px;
            width: 100%;
            background: #ffffff;
            border-radius: 32px;
            box-shadow: 0 20px 60px rgba(0, 20, 40, 0.08);
            padding: 2.5rem 2.8rem 3rem;
            transition: all 0.2s;
        }

        /* ===== 头部 ===== */
        .app-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            margin-bottom: 2rem;
            border-bottom: 2px solid #f0f4f8;
            padding-bottom: 1.5rem;
        }

        .app-header h1 {
            font-size: 1.9rem;
            font-weight: 700;
            letter-spacing: -0.5px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .app-header h1 i {
            color: #3b82f6;
            font-size: 2rem;
        }

        .app-header .badge {
            background: #eef2ff;
            color: #3b82f6;
            font-weight: 600;
            font-size: 0.85rem;
            padding: 0.4rem 1rem;
            border-radius: 40px;
            letter-spacing: 0.3px;
        }

        .header-actions {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        /* ===== 配置栏 ===== */
        .config-bar {
            background: #f8fafc;
            border-radius: 16px;
            padding: 1rem 1.5rem;
            margin-bottom: 2rem;
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 1.2rem 2rem;
            border: 1px solid #e9edf2;
        }

        .config-item {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.9rem;
            color: #2c3e50;
        }

        .config-item label {
            font-weight: 500;
            white-space: nowrap;
        }

        .config-item select,
        .config-item input[type="text"] {
            padding: 0.35rem 0.8rem;
            border-radius: 8px;
            border: 1px solid #d0d8e0;
            background: white;
            font-size: 0.85rem;
            outline: none;
            transition: 0.15s;
        }

        .config-item select:focus,
        .config-item input[type="text"]:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
        }

        .config-item input[type="text"] {
            width: 220px;
        }

        .config-item .api-key-hint {
            color: #6b7a8a;
            font-size: 0.75rem;
            cursor: help;
        }

        /* ===== 输入区 ===== */
        .input-section {
            margin-bottom: 2rem;
        }

        .input-section .label-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.6rem;
        }

        .input-section .label-row label {
            font-weight: 600;
            font-size: 1rem;
            color: #1a2b3c;
        }

        .input-section .label-row .word-count {
            font-size: 0.85rem;
            color: #6b7a8a;
            background: #f0f4f8;
            padding: 0.2rem 0.9rem;
            border-radius: 20px;
        }

        textarea#essayInput {
            width: 100%;
            height: 280px;
            padding: 1.2rem 1.5rem;
            font-size: 1rem;
            line-height: 1.7;
            border: 2px solid #e2e8f0;
            border-radius: 16px;
            resize: vertical;
            transition: 0.2s;
            font-family: 'Inter', monospace;
            background: #fafcfe;
            color: #1a2b3c;
        }

        textarea#essayInput:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.08);
            outline: none;
            background: #ffffff;
        }

        textarea#essayInput::placeholder {
            color: #a0b3c5;
            font-style: italic;
        }

        .action-row {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 1.2rem;
            justify-content: space-between;
            align-items: center;
        }

        .action-row .left-btns {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .btn {
            padding: 0.65rem 1.8rem;
            border: none;
            border-radius: 40px;
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
            transition: 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #f0f4f8;
            color: #1a2b3c;
        }

        .btn-primary {
            background: #3b82f6;
            color: white;
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.25);
        }
        .btn-primary:hover {
            background: #2563eb;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(59, 130, 246, 0.3);
        }
        .btn-primary:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        .btn-outline {
            background: transparent;
            border: 2px solid #d0d8e0;
        }
        .btn-outline:hover {
            background: #f0f4f8;
            border-color: #a0b3c5;
        }

        .btn-success {
            background: #10b981;
            color: white;
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.25);
        }
        .btn-success:hover {
            background: #059669;
            transform: translateY(-2px);
        }

        .btn-danger {
            background: #ef4444;
            color: white;
        }
        .btn-danger:hover {
            background: #dc2626;
        }

        /* ===== 进度条 ===== */
        .progress-wrapper {
            margin: 1.8rem 0 0.5rem;
            display: none;
        }
        .progress-wrapper.active {
            display: block;
        }
        .progress-bar {
            width: 100%;
            height: 6px;
            background: #e9edf2;
            border-radius: 10px;
            overflow: hidden;
        }
        .progress-bar .fill {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, #3b82f6, #8b5cf6);
            border-radius: 10px;
            transition: width 0.4s ease;
        }
        .progress-text {
            font-size: 0.8rem;
            color: #6b7a8a;
            margin-top: 6px;
            text-align: center;
        }

        /* ===== 结果面板 ===== */
        #resultsPanel {
            margin-top: 2.5rem;
            display: none;
            animation: fadeUp 0.5s ease;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .score-overview {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 1.2rem;
            margin-bottom: 2rem;
        }

        .score-card {
            background: #f8fafc;
            border-radius: 16px;
            padding: 1.2rem 1rem;
            text-align: center;
            border: 1px solid #e9edf2;
            transition: 0.15s;
        }
        .score-card:hover {
            border-color: #cbd5e1;
        }

        .score-card .label {
            font-size: 0.8rem;
            font-weight: 500;
            color: #6b7a8a;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .score-card .value {
            font-size: 2.4rem;
            font-weight: 700;
            margin: 6px 0 2px;
            color: #1a2b3c;
        }

        .score-card .sub {
            font-size: 0.75rem;
            color: #8a9aa8;
        }

        .score-card.total {
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            border-color: transparent;
            color: white;
        }
        .score-card.total .label {
            color: rgba(255, 255, 255, 0.75);
        }
        .score-card.total .value {
            color: white;
        }
        .score-card.total .sub {
            color: rgba(255, 255, 255, 0.7);
        }

        .score-card .stars {
            color: #f59e0b;
            font-size: 0.9rem;
            letter-spacing: 2px;
        }

        /* ===== 详细反馈 ===== */
        .detail-section {
            margin-top: 1.8rem;
        }

        .detail-section h3 {
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 10px;
            color: #1a2b3c;
        }

        .detail-section h3 i {
            color: #3b82f6;
        }

        .error-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
            max-height: 320px;
            overflow-y: auto;
            padding-right: 6px;
        }

        .error-item {
            background: #fefaf5;
            border-left: 4px solid #f59e0b;
            padding: 0.7rem 1rem;
            border-radius: 10px;
            font-size: 0.9rem;
            display: flex;
            align-items: flex-start;
            gap: 12px;
            border: 1px solid #f0e6d8;
        }

        .error-item .icon {
            color: #f59e0b;
            font-size: 1rem;
            margin-top: 2px;
            flex-shrink: 0;
        }

        .error-item .msg {
            flex: 1;
            color: #2c3e50;
        }

        .error-item .msg strong {
            background: #fef3c7;
            padding: 0.1rem 0.4rem;
            border-radius: 4px;
            font-weight: 600;
        }

        .error-item .suggestion {
            color: #3b82f6;
            font-weight: 500;
            margin-left: 6px;
        }

        .error-item .type-badge {
            font-size: 0.65rem;
            font-weight: 600;
            text-transform: uppercase;
            background: #e9edf2;
            padding: 0.15rem 0.7rem;
            border-radius: 20px;
            color: #4b5a6a;
            flex-shrink: 0;
        }

        .error-item .type-badge.spelling {
            background: #fce4ec;
            color: #c62828;
        }
        .error-item .type-badge.grammar {
            background: #e3f2fd;
            color: #0d47a1;
        }
        .error-item .type-badge.coherence {
            background: #f3e5f5;
            color: #6a1b9a;
        }
        .error-item .type-badge.content {
            background: #e8f5e9;
            color: #1b5e20;
        }

        .no-errors {
            color: #10b981;
            font-weight: 500;
            padding: 0.8rem 0;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* ===== AI 评分区域 ===== */
        .ai-section {
            margin-top: 2rem;
            padding: 1.5rem 1.8rem;
            background: #f0f7ff;
            border-radius: 16px;
            border: 1px dashed #93b4e8;
        }

        .ai-section .ai-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 10px;
        }

        .ai-section .ai-header h4 {
            font-weight: 600;
            color: #1a3a6b;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .ai-section .ai-header h4 i {
            color: #8b5cf6;
        }

        .ai-score-box {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            flex-wrap: wrap;
            margin-top: 0.8rem;
        }

        .ai-score-box .ai-value {
            font-size: 2.2rem;
            font-weight: 700;
            color: #1a3a6b;
        }

        .ai-score-box .ai-label {
            color: #3a5a7b;
            font-size: 0.9rem;
        }

        .ai-score-box .ai-detail {
            color: #4a6a8b;
            font-size: 0.9rem;
            flex: 1;
            min-width: 150px;
        }

        .ai-score-box .ai-detail span {
            display: block;
            margin-top: 4px;
            font-size: 0.85rem;
            color: #5a7a9b;
        }

        .btn-ai {
            background: #8b5cf6;
            color: white;
            border: none;
            padding: 0.5rem 1.5rem;
            border-radius: 40px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .btn-ai:hover {
            background: #7c3aed;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(139, 92, 246, 0.3);
        }
        .btn-ai:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        /* ===== 响应式 ===== */
        @media (max-width: 700px) {
            .app-container {
                padding: 1.5rem 1.2rem;
            }
            .app-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 12px;
            }
            .app-header h1 {
                font-size: 1.5rem;
            }
            .config-bar {
                flex-direction: column;
                align-items: stretch;
                gap: 10px;
            }
            .config-item {
                flex-wrap: wrap;
            }
            .config-item input[type="text"] {
                width: 100%;
            }
            .action-row {
                flex-direction: column;
                align-items: stretch;
            }
            .action-row .left-btns {
                justify-content: center;
            }
            .btn {
                justify-content: center;
                padding: 0.6rem 1.2rem;
            }
            .score-overview {
                grid-template-columns: repeat(2, 1fr);
            }
            .ai-section {
                padding: 1rem;
            }
            .ai-score-box {
                flex-direction: column;
                align-items: flex-start;
            }
        }

        @media (max-width: 450px) {
            .score-overview {
                grid-template-columns: 1fr 1fr;
                gap: 0.8rem;
            }
            .score-card .value {
                font-size: 1.8rem;
            }
            textarea#essayInput {
                height: 200px;
            }
        }

        /* ===== 滚动条 ===== */
        .error-list::-webkit-scrollbar {
            width: 5px;
        }
        .error-list::-webkit-scrollbar-track {
            background: #f0f4f8;
            border-radius: 8px;
        }
        .error-list::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 8px;
        }

        /* ===== 工具类 ===== */
        .hidden {
            display: none !important;
        }
        .text-muted {
            color: #6b7a8a;
            font-size: 0.85rem;
        }
        .mt-1 {
            margin-top: 0.5rem;
        }
        .flex-center {
            display: flex;
            align-items: center;
            gap: 6px;
        }
    </style>
</head>
<body>

    <div class="app-container" id="app">
        <!-- 头部 -->
        <header class="app-header">
            <h1>
                <i class="fas fa-pen-fancy"></i>
                托福写作评分
                <span class="badge">6 分制</span>
            </h1>
            <div class="header-actions">
                <span class="text-muted" style="font-size:0.85rem;">
                    <i class="fas fa-code-branch"></i> 开源可扩展
                </span>
            </div>
        </header>

        <!-- 配置栏 -->
        <div class="config-bar">
            <div class="config-item">
                <label><i class="fas fa-globe"></i> 语言</label>
                <select id="langSelect">
                    <option value="en-US">英文 (美式)</option>
                    <option value="en-GB">英文 (英式)</option>
                </select>
            </div>
            <div class="config-item">
                <label><i class="fas fa-robot"></i> AI 评分</label>
                <select id="aiProvider">
                    <option value="none">无 (仅本地)</option>
                    <option value="openai">OpenAI</option>
                    <option value="claude">Claude</option>
                </select>
            </div>
            <div class="config-item" id="apiKeyGroup">
                <label><i class="fas fa-key"></i> API Key</label>
                <input type="text" id="apiKeyInput" placeholder="sk-..." />
                <span class="api-key-hint" title="AI 评分需要 API Key，不会保存">ⓘ</span>
            </div>
        </div>

        <!-- 输入区 -->
        <section class="input-section">
            <div class="label-row">
                <label for="essayInput"><i class="fas fa-file-alt"></i> 粘贴你的托福作文</label>
                <span class="word-count" id="wordCount">0 词</span>
            </div>
            <textarea id="essayInput" placeholder="在此粘贴或输入你的托福作文（建议 150–400 词）&#10;例如：The advancement of technology has profoundly transformed the way we communicate..." spellcheck="false"></textarea>

            <div class="action-row">
                <div class="left-btns">
                    <button class="btn btn-primary" id="btnEvaluate">
                        <i class="fas fa-chart-simple"></i> 开始评分
                    </button>
                    <button class="btn btn-outline" id="btnClear">
                        <i class="fas fa-eraser"></i> 清空
                    </button>
                    <button class="btn btn-outline" id="btnExample">
                        <i class="fas fa-file-pen"></i> 示例作文
                    </button>
                </div>
                <span style="font-size:0.8rem; color:#8a9aa8;">
                    <i class="fas fa-info-circle"></i> 支持外接 LanguageTool + AI
                </span>
            </div>

            <!-- 进度 -->
            <div class="progress-wrapper" id="progressWrapper">
                <div class="progress-bar">
                    <div class="fill" id="progressFill"></div>
                </div>
                <div class="progress-text" id="progressText">准备中...</div>
            </div>
        </section>

        <!-- 结果面板 -->
        <div id="resultsPanel">
            <!-- 总分卡片 -->
            <div class="score-overview" id="scoreOverview">
                <!-- 由 JS 动态渲染 -->
            </div>

            <!-- 详细错误 -->
            <div class="detail-section">
                <h3><i class="fas fa-list-check"></i> 详细反馈与建议</h3>
                <div id="errorListContainer">
                    <!-- 由 JS 动态渲染 -->
                </div>
            </div>

            <!-- 连贯性 & 内容 详情 -->
            <div class="detail-section" style="margin-top:1.2rem;">
                <h3><i class="fas fa-chart-line"></i> 连贯性 &amp; 内容分析</h3>
                <div id="coherenceContentDetail" style="background:#f8fafc; border-radius:12px; padding:1rem 1.4rem; border:1px solid #e9edf2;">
                    <!-- 由 JS 动态渲染 -->
                </div>
            </div>

            <!-- AI 评分外接区域 -->
            <div class="ai-section" id="aiSection">
                <div class="ai-header">
                    <h4><i class="fas fa-brain"></i> AI 智能评分 (外接)</h4>
                    <button class="btn-ai" id="btnAiScore">
                        <i class="fas fa-microchip"></i> 调用 AI 评分
                    </button>
                </div>
                <div class="ai-score-box" id="aiScoreBox">
                    <div class="ai-value" id="aiScoreValue">—</div>
                    <div class="ai-label">AI 评分 (0–6)</div>
                    <div class="ai-detail" id="aiScoreDetail">
                        点击上方按钮，使用 AI 模型评估作文
                        <span>支持 OpenAI / Claude</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- 底部 -->
        <div style="margin-top:2.5rem; border-top:1px solid #eef2f6; padding-top:1.2rem; display:flex; justify-content:space-between; flex-wrap:wrap; gap:10px; font-size:0.8rem; color:#8a9aa8;">
            <span><i class="fas fa-code"></i> 基于 LanguageTool 开源 + 本地算法</span>
            <span>
                <i class="fas fa-github"></i> 可外接任意 AI 评分系统
                <span style="margin-left:12px; background:#eef2f6; padding:0.1rem 0.8rem; border-radius:20px;">v2.0</span>
            </span>
        </div>
    </div>

    <script>
        // ================================================================
        //  TOEFL 写作评分系统 · 完整逻辑
        //  功能：拼写 / 语法 / 连贯性 / 内容 · 满分 6 分
        //  外接：LanguageTool API (开源) + AI (OpenAI/Claude)
        // ================================================================

        (function() {
            'use strict';

            // ---------- DOM 引用 ----------
            const essayInput = document.getElementById('essayInput');
            const wordCount = document.getElementById('wordCount');
            const btnEvaluate = document.getElementById('btnEvaluate');
            const btnClear = document.getElementById('btnClear');
            const btnExample = document.getElementById('btnExample');
            const btnAiScore = document.getElementById('btnAiScore');
            const resultsPanel = document.getElementById('resultsPanel');
            const scoreOverview = document.getElementById('scoreOverview');
            const errorListContainer = document.getElementById('errorListContainer');
            const coherenceContentDetail = document.getElementById('coherenceContentDetail');
            const progressWrapper = document.getElementById('progressWrapper');
            const progressFill = document.getElementById('progressFill');
            const progressText = document.getElementById('progressText');

            const langSelect = document.getElementById('langSelect');
            const aiProvider = document.getElementById('aiProvider');
            const apiKeyInput = document.getElementById('apiKeyInput');
            const aiScoreValue = document.getElementById('aiScoreValue');
            const aiScoreDetail = document.getElementById('aiScoreDetail');

            // ---------- 状态 ----------
            let isEvaluating = false;
            let lastResult = null; // 缓存最近一次评分结果

            // ---------- 辅助函数 ----------
            function getWordCount(text) {
                const clean = text.replace(/[^\w\s]/g, ' ').replace(/\s+/g, ' ').trim();
                return clean === '' ? 0 : clean.split(/\s+/).length;
            }

            function updateWordCount() {
                const count = getWordCount(essayInput.value);
                wordCount.textContent = count + ' 词';
                return count;
            }

            // 更新进度
            function setProgress(percent, text) {
                progressWrapper.classList.add('active');
                progressFill.style.width = Math.min(100, Math.max(0, percent)) + '%';
                progressText.textContent = text || (percent + '%');
                if (percent >= 100) {
                    setTimeout(() => {
                        progressWrapper.classList.remove('active');
                    }, 800);
                }
            }

            // ---------- 示例作文 ----------
            function loadExample() {
