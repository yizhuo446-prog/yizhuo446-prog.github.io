            // ---------- 核心评分函数 (本地) ----------
            async function evaluateEssay(text, lang) {
                if (!text || text.trim().length < 10) {
                    throw new Error('作文内容太短，请至少输入 10 个字符。');
                }

                const wordCountVal = getWordCount(text);
                if (wordCountVal < 30) {
                    throw new Error('作文词数过少（建议 ≥ 50 词），请补充内容。');
                }

                setProgress(5, '开始分析...');

                // 1. 调用 LanguageTool API (拼写 + 语法)
                let ltMatches = [];
                let ltError = null;
                try {
                    setProgress(15, '调用 LanguageTool 检查拼写与语法...');
                    const response = await callLanguageTool(text, lang);
                    ltMatches = response.matches || [];
                    setProgress(50, 'LanguageTool 检查完成');
                } catch (err) {
                    ltError = err.message || 'LanguageTool 服务不可用，使用本地备用检查。';
                    console.warn('LanguageTool 调用失败:', err);
                    setProgress(50, '使用本地备用检查...');
                }

                // 2. 本地拼写备用检查 (简单字典)
                const localSpellingErrors = ltError ? checkSpellingLocal(text) : [];

                // 3. 本地连贯性分析
                const coherenceResult = analyzeCoherence(text);

                // 4. 本地内容分析
                const contentResult = analyzeContent(text);

                // 5. 汇总错误
                const allErrors = buildErrorList(ltMatches, localSpellingErrors, coherenceResult, contentResult, text);

                // 6. 计算各维度分数
                const scores = computeScores(allErrors, ltMatches, coherenceResult, contentResult, text, wordCountVal);

                setProgress(90, '生成评分报告...');

                const result = {
                    scores: scores,
                    errors: allErrors,
                    coherence: coherenceResult,
                    content: contentResult,
                    wordCount: wordCountVal,
                    ltMatches: ltMatches,
                    ltError: ltError,
                    text: text,
                };

                setProgress(100, '评分完成！');
                return result;
            }

            // ---------- 调用 LanguageTool API ----------
            async function callLanguageTool(text, lang) {
                const url = 'https://api.languagetool.org/v2/check';
                const params = new URLSearchParams();
                params.append('text', text);
                params.append('language', lang || 'en-US');
                params.append('enabledOnly', 'false');
                params.append('level', 'picky');

                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: params.toString(),
                });

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                }
                return await response.json();
            }

            // ---------- 本地拼写备用检查 (简易) ----------
            // 使用常见英文单词列表 (仅作备用)
            function checkSpellingLocal(text) {
                const commonWords = new Set([
                    'the', 'be', 'to', 'of', 'and', 'a', 'in', 'that', 'have', 'i',
                    'it', 'for', 'not', 'on', 'with', 'he', 'as', 'you', 'do', 'at',
                    'this', 'but', 'his', 'by', 'from', 'they', 'we', 'say', 'her', 'she',
                    'or', 'an', 'will', 'my', 'one', 'all', 'would', 'there', 'their', 'what',
                    'so', 'up', 'out', 'if', 'about', 'who', 'get', 'which', 'go', 'me',
                    'when', 'make', 'can', 'like', 'time', 'no', 'just', 'him', 'know', 'take',
                    'people', 'into', 'year', 'your', 'good', 'some', 'could', 'them', 'see', 'other',
                    'than', 'then', 'now', 'look', 'only', 'come', 'its', 'over', 'think', 'also',
                    'back', 'after', 'use', 'two', 'how', 'our', 'work', 'first', 'well', 'way',
                    'even', 'new', 'want', 'because', 'any', 'these', 'give', 'day', 'most', 'us',
                    'technology', 'communication', 'education', 'development', 'social', 'media', 'internet',
                    'information', 'knowledge', 'opportunity', 'challenge', 'benefit', 'advantage', 'disadvantage',
                    'global', 'cultural', 'economic', 'political', 'environmental', 'sustainable', 'innovation',
                    'future', 'health', 'wellness', 'community', 'connection', 'relationship', 'interaction',
                    'democracy', 'freedom', 'equality', 'diversity', 'inclusion', 'justice', 'peace',
                    'science', 'research', 'discovery', 'progress', 'tradition', 'heritage', 'identity',
                    'student', 'teacher', 'university', 'course', 'degree', 'career', 'profession',
                    'opportunity', 'challenge', 'decision', 'solution', 'problem', 'issue', 'concern',
                    'example', 'instance', 'context', 'perspective', 'viewpoint', 'argument', 'evidence',
                ]);

                const words = text.toLowerCase().replace(/[^a-z\s']/g, ' ').split(/\s+/).filter(w => w.length > 0);
                const errors = [];
                const seen = new Set();
                for (const w of words) {
                    if (w.length > 0 && !commonWords.has(w) && !seen.has(w)) {
                        // 检查是否包含数字或特殊字符
                        if (!/^[a-z']+$/.test(w)) continue;
                        // 忽略常见学术词 (这里简单处理)
                        if (w.length > 12) continue; // 长词可能是专业术语
                        seen.add(w);
                        // 只在文本中标记一次
                        const idx = text.toLowerCase().indexOf(w);
                        if (idx !== -1) {
                            errors.push({
                                type: 'spelling',
                                message: `"${w}" 可能是拼写错误，请检查。`,
                                offset: idx,
                                length: w.length,
                                replacements: [],
                                context: text.substring(Math.max(0, idx - 10), Math.min(text.length, idx + w.length + 10)),
                            });
                        }
                    }
                }
                return errors.slice(0, 15); // 限制数量
            }

            // ---------- 连贯性分析 ----------
            function analyzeCoherence(text) {
                const sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 5);
                const sentenceCount = sentences.length;
                if (sentenceCount < 2) {
                    return {
                        score: 2.0,
                        details: ['句子数量太少，建议增加论证段落。'],
                        transitionCount: 0,
                        sentenceLenAvg: 0,
                        sentenceLenStd: 0,
                        paragraphCount: 1,
                    };
                }

                // 连接词列表
                const transitions = [
                    'however', 'therefore', 'moreover', 'furthermore', 'in addition', 'additionally',
                    'consequently', 'hence', 'thus', 'accordingly', 'as a result', 'for example',
                    'for instance', 'specifically', 'in particular', 'on the other hand', 'alternatively',
                    'nevertheless', 'nonetheless', 'whereas', 'while', 'although', 'though', 'even though',
                    'despite', 'in spite of', 'since', 'because', 'as', 'due to', 'owing to',
                    'first', 'second', 'third', 'finally', 'lastly', 'in conclusion', 'to conclude',
                    'overall', 'ultimately', 'in summary', 'to summarize',
                ];

                const lowerText = text.toLowerCase();
                let transitionCount = 0;
                for (const t of transitions) {
                    const regex = new RegExp('\\b' + t.replace(/\s/g, '\\s+') + '\\b', 'gi');
                    const matches = lowerText.match(regex);
                    if (matches) transitionCount += matches.length;
                }

                // 句子长度
                const lengths = sentences.map(s => s.trim().split(/\s+/).length);
                const avgLen = lengths.reduce((a, b) => a + b, 0) / lengths.length;
                const variance = lengths.reduce((a, b) => a + (b - avgLen) ** 2, 0) / lengths.length;
                const stdDev = Math.sqrt(variance);

                // 段落数 (基于换行)
                const paragraphs = text.split(/\n+/).filter(p => p.trim().length > 10);
                const paragraphCount = paragraphs.length || 1;

                // 评分：连接词密度、句子长度变化、段落数
                let score = 3.0;
                const details = [];

                // 连接词密度 (每10句至少1个)
                const transDensity = transitionCount / Math.max(1, sentenceCount);
                if (transDensity > 0.3) {
                    score += 1.2;
                    details.push('连接词使用丰富，逻辑流畅。');
                } else if (transDensity > 0.15) {
                    score += 0.6;
                    details.push('连接词使用适当，可进一步丰富。');
                } else {
                    score -= 0.5;
                    details.push('连接词较少，建议增加过渡词增强连贯性。');
                }

                // 句子长度标准差 (理想: 8-15)
                if (stdDev > 5 && stdDev < 15) {
                    score += 0.8;
                    details.push('句子长度变化适中，节奏良好。');
                } else if (stdDev >= 15) {
                    score += 0.4;
                    details.push('句子长度变化较大，部分句子可能过长或过短。');
                } else {
                    score -= 0.3;
                    details.push('句子长度变化较小，建议丰富句式。');
                }

                // 段落数
                if (paragraphCount >= 3) {
                    score += 0.6;
                    details.push('段落结构清晰，符合学术写作规范。');
                } else if (paragraphCount === 2) {
                    score += 0.2;
                    details.push('建议增加段落，使结构更完整。');
                } else {
                    score -= 0.4;
                    details.push('段落较少，建议分段论述。');
                }

                // 句子数量
                if (sentenceCount < 6) {
                    score -= 0.5;
                    details.push('句子数量偏少，内容可能不够充实。');
                }

                // 限制范围 1-6
                score = Math.min(6, Math.max(1, score));

                return {
                    score: Math.round(score * 10) / 10,
                    details: details,
                    transitionCount: transitionCount,
                    sentenceLenAvg: Math.round(avgLen * 10) / 10,
                    sentenceLenStd: Math.round(stdDev * 10) / 10,
                    paragraphCount: paragraphCount,
                    sentenceCount: sentenceCount,
                };
            }

            // ---------- 内容分析 ----------
            function analyzeContent(text) {
                const words = text.toLowerCase().replace(/[^a-z\s']/g, ' ').split(/\s+/).filter(w => w.length > 0);
                const wordCount = words.length;
                if (wordCount < 10) {
                    return {
                        score: 2.0,
                        details: ['内容过于简短，无法有效评估。'],
                        ttr: 0,
                        avgWordLen: 0,
                        complexRatio: 0,
                    };
                }

                // 词汇多样性 (Type-Token Ratio)
                const unique = new Set(words);
                const ttr = unique.size / wordCount;

                // 平均词长
                const totalLen = words.reduce((a, b) => a + b.length, 0);
                const avgWordLen = totalLen / wordCount;

                // 复杂词比例 (长度 >= 7)
                const complexCount = words.filter(w => w.length >= 7).length;
                const complexRatio = complexCount / wordCount;

                // 评分
                let score = 3.0;
                const details = [];

                // TTR: 理想 > 0.5
                if (ttr > 0.6) {
                    score += 1.2;
                    details.push('词汇非常丰富，多样性优秀。');
                } else if (ttr > 0.5) {
                    score += 0.7;
                    details.push('词汇多样性良好。');
                } else if (ttr > 0.4) {
                    score += 0.2;
                    details.push('词汇多样性一般，建议使用更多同义词。');
                } else {
                    score -= 0.6;
                    details.push('词汇重复较多，建议丰富表达。');
                }

                // 平均词长: 理想 4.5-6.5
                if (avgWordLen > 5.5 && avgWordLen < 7) {
                    score += 0.7;
                    details.push('词汇难度适中，学术性较好。');
                } else if (avgWordLen >= 7) {
                    score += 0.3;
                    details.push('词汇难度较高，注意可读性。');
                } else if (avgWordLen < 4.5) {
                    score -= 0.4;
                    details.push('词汇偏简单，建议使用更学术的词汇。');
                }

                // 复杂词比例: 理想 > 0.15
                if (complexRatio > 0.25) {
                    score += 0.6;
                    details.push('使用较多高级词汇，表达能力强。');
                } else if (complexRatio > 0.15) {
                    score += 0.3;
                    details.push('高级词汇使用适当。');
                } else {
                    details.push('高级词汇较少，可尝试使用更精准的学术词汇。');
                }

                // 词数
                if (wordCount < 100) {
                    score -= 0.3;
                    details.push('文章词数偏少，建议扩充内容。');
                } else if (wordCount > 350) {
                    details.push('文章篇幅较长，注意精炼表达。');
                }

                score = Math.min(6, Math.max(1, score));
                return {
                    score: Math.round(score * 10) / 10,
                    details: details,
                    ttr: Math.round(ttr * 100) / 100,
                    avgWordLen: Math.round(avgWordLen * 10) / 10,
                    complexRatio: Math.round(complexRatio * 100) / 100,
                    wordCount: wordCount,
                };
            }

            // ---------- 构建错误列表 ----------
            function buildErrorList(ltMatches, localErrors, coherence, content, text) {
                const errors = [];

                // LanguageTool 错误
                for (const m of ltMatches) {
                    let type = 'grammar';
                    if (m.rule && m.rule.category && m.rule.category.id) {
                        const cat = m.rule.category.id;
                        if (cat === 'TYPOS' || cat === 'MISSPELLING') {
                            type = 'spelling';
                        } else if (cat === 'GRAMMAR') {
                            type = 'grammar';
                        } else {
                            type = 'grammar';
                        }
                    }
                    const msg = m.message || '语法/拼写问题';
                    const replacements = m.replacements ? m.replacements.map(r => r.value) : [];
                    const context = m.context ? m.context.text : '';
                    errors.push({
                        type: type,
                        message: msg,
                        offset: m.offset || 0,
                        length: m.length || 1,
                        replacements: replacements,
                        context: context,
                        rule: m.rule ? m.rule.id : '',
                    });
                }

                // 本地拼写错误 (去重)
                for (const e of localErrors) {
                    // 检查是否已存在类似错误
                    const dup = errors.some(ex =>
                        ex.type === 'spelling' &&
                        ex.message === e.message
                    );
                    if (!dup) {
                        errors.push(e);
                    }
                }

                // 连贯性建议 (作为错误展示)
                if (coherence.details) {
                    for (const d of coherence.details) {
                        if (d.includes('较少') || d.includes('偏少') || d.includes('建议')) {
                            errors.push({
                                type: 'coherence',
                                message: '📌 ' + d,
                                offset: 0,
                                length: 0,
                                replacements: [],
                                context: '',
                            });
                        }
                    }
                }

                // 内容建议
                if (content.details) {
                    for (const d of content.details) {
                        if (d.includes('重复') || d.includes('偏简单') || d.includes('较少') || d.includes('建议')) {
                            errors.push({
                                type: 'content',
                                message: '📌 ' + d,
                                offset: 0,
                                length: 0,
                                replacements: [],
                                context: '',
                            });
                        }
                    }
                }

                // 限制数量，避免太多
                return errors.slice(0, 30);
            }

            // ---------- 计算各维度分数 ----------
            function computeScores(errors, ltMatches, coherence, content, text, wordCount) {
                // 1. 拼写分数 (基于 LT 拼写错误 + 本地)
                const spellingErrors = errors.filter(e => e.type === 'spelling');
                const spellingCount = spellingErrors.length;
                let spellingScore = 6.0;
                if (wordCount > 0) {
                    const rate = spellingCount / wordCount * 100; // 每100词错误数
                    if (rate < 0.5) spellingScore = 6.0;
                    else if (rate < 1.5) spellingScore = 5.5;
                    else if (rate < 2.5) spellingScore = 4.5;
                    else if (rate < 4.0) spellingScore = 3.5;
                    else if (rate < 6.0) spellingScore = 2.5;
                    else spellingScore = 1.5;
                }
                spellingScore = Math.min(6, Math.max(1, spellingScore));

                // 2. 语法分数 (基于 LT 语法错误)
                const grammarErrors = errors.filter(e => e.type === 'grammar');
                const grammarCount = grammarErrors.length + Math.floor(ltMatches.length * 0.3); // 综合
                let grammarScore = 6.0;
                if (wordCount > 0) {
                    const rate = grammarCount / wordCount * 100;
                    if (rate < 0.8) grammarScore = 6.0;
                    else if (rate < 2.0) grammarScore = 5.0;
                    else if (rate < 3.5) grammarScore = 4.0;
                    else if (rate < 5.5) grammarScore = 3.0;
                    else if (rate < 8.0) grammarScore = 2.0;
                    else grammarScore = 1.0;
                }
                grammarScore = Math.min(6, Math.max(1, grammarScore));

                // 3. 连贯性分数 (来自 coherence)
                let coherenceScore = coherence.score || 3.0;

                // 4. 内容分数 (来自 content)
                let contentScore = content.score || 3.0;

                // 总分 (加权)
                const totalScore =
                    spellingScore * 0.20 +
                    grammarScore * 0.25 +
                    coherenceScore * 0.25 +
                    contentScore * 0.30;

                const finalTotal = Math.min(6, Math.max(1, Math.round(totalScore * 10) / 10));

                return {
                    spelling: Math.round(spellingScore * 10) / 10,
                    grammar: Math.round(grammarScore * 10) / 10,
                    coherence: Math.round(coherenceScore * 10) / 10,
                    content: Math.round(contentScore * 10) / 10,
                    total: finalTotal,
                    spellingCount: spellingCount,
                    grammarCount: grammarCount,
                };
            }

            // ---------- 渲染结果 ----------
            function renderResults(result) {
                const s = result.scores;

                // 1. 总分卡片
                const stars = '★'.repeat(Math.round(s.total)) + '☆'.repeat(6 - Math.round(s.total));
