                    </div>
                    <div class="score-card">
                        <div class="label"><i class="fas fa-code"></i> 语法</div>
                        <div class="value">${s.grammar}</div>
                        <div class="sub">${s.grammarCount} 处错误</div>
                    </div>
                    <div class="score-card">
                        <div class="label"><i class="fas fa-link"></i> 连贯性</div>
                        <div class="value">${s.coherence}</div>
                        <div class="sub">${result.coherence.transitionCount || 0} 个连接词</div>
                    </div>
                    <div class="score-card">
                        <div class="label"><i class="fas fa-book"></i> 内容</div>
                        <div class="value">${s.content}</div>
                        <div class="sub">${result.content.wordCount || result.wordCount} 词</div>
                    </div>
                `;

                // 2. 错误列表
                if (result.errors.length === 0) {
                    errorListContainer.innerHTML = `
                        <div class="no-errors">
                            <i class="fas fa-check-circle"></i> 太棒了！没有发现明显错误。
                        </div>
                    `;
                } else {
                    let html = '<div class="error-list">';
                    for (const err of result.errors) {
                        const typeLabel = err.type === 'spelling' ? '拼写' :
                            err.type === 'grammar' ? '语法' :
                            err.type === 'coherence' ? '连贯' : '内容';
                        const typeClass = err.type === 'spelling' ? 'spelling' :
                            err.type === 'grammar' ? 'grammar' :
                            err.type === 'coherence' ? 'coherence' : 'content';
                        const icon = err.type === 'spelling' ? 'fa-pen' :
                            err.type === 'grammar' ? 'fa-code' :
                            err.type === 'coherence' ? 'fa-link' : 'fa-book';
                        const suggestion = err.replacements && err.replacements.length > 0 ?
                            ` → 建议: ${err.replacements.slice(0, 3).join(', ')}` :
                            '';
                        const contextText = err.context ? `…${err.context}…` : '';
                        html += `
                            <div class="error-item">
                                <div class="icon"><i class="fas ${icon}"></i></div>
                                <div class="msg">
                                    <strong>${err.message}</strong>
                                    ${suggestion ? `<span class="suggestion">${suggestion}</span>` : ''}
                                    ${contextText ? `<br><span style="font-size:0.8rem;color:#6b7a8a;">${contextText}</span>` : ''}
                                </div>
                                <span class="type-badge ${typeClass}">${typeLabel}</span>
                            </div>
                        `;
                    }
                    html += '</div>';
                    errorListContainer.innerHTML = html;
                }

                // 3. 连贯性 & 内容详情
                const c = result.coherence;
                const ct = result.content;
                coherenceContentDetail.innerHTML = `
                    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(200px,1fr)); gap:1rem;">
                        <div>
                            <div style="font-weight:600; color:#2c3e50;">📊 连贯性</div>
                            <div style="font-size:0.9rem; color:#4b5a6a; margin-top:4px;">
                                <div>句子数: ${c.sentenceCount || 0}</div>
                                <div>连接词: ${c.transitionCount || 0}</div>
                                <div>平均句长: ${c.sentenceLenAvg || 0} 词</div>
                                <div>句长标准差: ${c.sentenceLenStd || 0}</div>
                                <div>段落数: ${c.paragraphCount || 1}</div>
                            </div>
                            ${c.details ? c.details.map(d => `<div style="font-size:0.85rem; color:#3b82f6; margin-top:2px;">✓ ${d}</div>`).join('') : ''}
                        </div>
                        <div>
                            <div style="font-weight:600; color:#2c3e50;">📖 内容质量</div>
                            <div style="font-size:0.9rem; color:#4b5a6a; margin-top:4px;">
                                <div>词汇多样性 (TTR): ${ct.ttr || 0}</div>
                                <div>平均词长: ${ct.avgWordLen || 0}</div>
                                <div>高级词汇比: ${ct.complexRatio ? (ct.complexRatio * 100).toFixed(1) + '%' : '0%'}</div>
                                <div>总词数: ${ct.wordCount || result.wordCount}</div>
                            </div>
                            ${ct.details ? ct.details.map(d => `<div style="font-size:0.85rem; color:#10b981; margin-top:2px;">✓ ${d}</div>`).join('') : ''}
                        </div>
                    </div>
                `;

                resultsPanel.style.display = 'block';
                // 滚动到结果
                resultsPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }

            // ---------- AI 评分 (外接) ----------
            async function callAiScore(text, provider, apiKey) {
                if (!apiKey || apiKey.trim().length < 10) {
                    throw new Error('请先输入有效的 API Key');
                }

                const prompt =
                    `You are an expert TOEFL writing evaluator. Grade the following essay on a scale of 0-6 (with 0.5 increments). Provide a brief justification and highlight strengths and weaknesses. Keep the response under 150 words.

            Essay:
            ${text}

            Output format: score: X.X | justification: ...`;

                let response;
                if (provider === 'openai') {
                    response = await fetch('https://api.openai.com/v1/chat/completions', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Authorization': `Bearer ${apiKey}`,
                        },
                        body: JSON.stringify({
                            model: 'gpt-3.5-turbo',
                            messages: [{ role: 'user', content: prompt }],
                            temperature: 0.5,
                            max_tokens: 200,
                        }),
                    });
                } else if (provider === 'claude') {
                    // Claude API (Anthropic)
                    response = await fetch('https://api.anthropic.com/v1/messages', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'x-api-key': apiKey,
                            'anthropic-version': '2023-06-01',
                        },
                        body: JSON.stringify({
                            model: 'claude-3-haiku-20240307',
                            messages: [{ role: 'user', content: prompt }],
                            max_tokens: 200,
                            temperature: 0.5,
                        }),
                    });
                } else {
                    throw new Error('不支持的 AI 提供商');
                }

                if (!response.ok) {
                    const errText = await response.text();
                    throw new Error(`API 错误 (${response.status}): ${errText}`);
                }

                const data = await response.json();
                let contentText = '';
                if (provider === 'openai') {
                    contentText = data.choices?.[0]?.message?.content || '';
                } else if (provider === 'claude') {
                    contentText = data.content?.[0]?.text || '';
                }

                // 解析分数
                const scoreMatch = contentText.match(/score:\s*(\d+\.?\d*)/i);
                let score = null;
                if (scoreMatch) {
                    score = parseFloat(scoreMatch[1]);
                    if (isNaN(score) || score < 0 || score > 6) score = null;
                }
                if (score === null) {
                    // 尝试更宽松的匹配
                    const match2 = contentText.match(/(\d+\.?\d*)\s*\/\s*6/i);
                    if (match2) {
                        score = parseFloat(match2[1]);
                        if (isNaN(score) || score < 0 || score > 6) score = null;
                    }
                }
                if (score === null) {
                    // 尝试找任何数字
                    const match3 = contentText.match(/\b(\d+\.?\d*)\b/);
                    if (match3) {
                        score = parseFloat(match3[1]);
                        if (isNaN(score) || score < 0 || score > 6) score = null;
                    }
                }

                return {
                    score: score,
                    detail: contentText,
                    raw: contentText,
                };
            }

            // ---------- 主流程：评分 ----------
            async function handleEvaluate() {
                if (isEvaluating) return;
                const text = essayInput.value;
                if (!text || text.trim().length < 5) {
                    alert('请先输入或粘贴作文内容。');
                    return;
                }

                isEvaluating = true;
                btnEvaluate.disabled = true;
                btnEvaluate.innerHTML = '<i class="fas fa-spinner fa-spin"></i> 评分中...';

                try {
                    const lang = langSelect.value;
                    const result = await evaluateEssay(text, lang);
                    lastResult = result;
                    renderResults(result);

                    // 如果 AI 已配置，自动调用？
                    // 不自动调用，由用户点击

                } catch (err) {
                    alert('评分出错: ' + err.message);
                    console.error(err);
                } finally {
                    isEvaluating = false;
                    btnEvaluate.disabled = false;
                    btnEvaluate.innerHTML = '<i class="fas fa-chart-simple"></i> 开始评分';
                }
            }

            // ---------- AI 评分按钮 ----------
            async function handleAiScore() {
                if (!lastResult) {
                    alert('请先点击 "开始评分" 进行本地评估，再调用 AI 评分。');
                    return;
                }
                const provider = aiProvider.value;
                if (provider === 'none') {
                    alert('请在配置栏中选择 AI 提供商 (OpenAI 或 Claude)。');
                    return;
                }
                const apiKey = apiKeyInput.value.trim();
                if (!apiKey) {
                    alert('请在配置栏中输入 API Key。');
                    return;
                }

                btnAiScore.disabled = true;
                btnAiScore.innerHTML = '<i class="fas fa-spinner fa-spin"></i> AI 分析中...';
                aiScoreValue.textContent = '…';
                aiScoreDetail.innerHTML = '正在调用 AI 模型，请稍候...';

                try {
                    const text = essayInput.value;
                    const result = await callAiScore(text, provider, apiKey);
                    if (result.score !== null && !isNaN(result.score)) {
                        aiScoreValue.textContent = result.score.toFixed(1);
                        const stars = '★'.repeat(Math.round(result.score)) + '☆'.repeat(6 - Math.round(result.score));
                        aiScoreDetail.innerHTML =
                            `<strong>AI 评分 ${result.score.toFixed(1)} / 6.0</strong> ${stars}<br><span style="font-size:0.85rem;">${result.detail || '分析完成'}</span>`;
                    } else {
                        aiScoreValue.textContent = '?';
                        aiScoreDetail.innerHTML =
                            `AI 返回了结果但无法解析分数。原始响应：<br><span style="font-size:0.8rem;color:#5a7a9b;">${result.detail || '无内容'}</span>`;
                    }
                } catch (err) {
                    aiScoreValue.textContent = '⚠';
                    aiScoreDetail.innerHTML = `<span style="color:#dc2626;">AI 评分失败: ${err.message}</span>`;
                    console.error(err);
                } finally {
                    btnAiScore.disabled = false;
                    btnAiScore.innerHTML = '<i class="fas fa-microchip"></i> 调用 AI 评分';
                }
            }

            // ---------- 事件绑定 ----------
            essayInput.addEventListener('input', updateWordCount);
            btnEvaluate.addEventListener('click', handleEvaluate);
            btnClear.addEventListener('click', clearAll);
            btnExample.addEventListener('click', loadExample);
            btnAiScore.addEventListener('click', handleAiScore);

            // 配置显示
            aiProvider.addEventListener('change', function() {
                const group = document.getElementById('apiKeyGroup');
                if (this.value === 'none') {
                    group.style.opacity = '0.4';
                    apiKeyInput.disabled = true;
                } else {
                    group.style.opacity = '1';
                    apiKeyInput.disabled = false;
                }
            });
            // 初始化
            aiProvider.dispatchEvent(new Event('change'));

            // 快捷键: Ctrl+Enter 评分
            essayInput.addEventListener('keydown', function(e) {
                if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
                    e.preventDefault();
                    btnEvaluate.click();
                }
            });

            // 加载示例
            loadExample();

            console.log('✅ 托福写作评分系统已加载');
            console.log('📌 支持 LanguageTool 开源 + 本地算法 + AI 外接');
            console.log('💡 按 Ctrl+Enter 快速评分');

        })();
    </script>
