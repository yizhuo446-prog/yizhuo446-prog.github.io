            // ---------- 清空 ----------
            function clearAll() {
                essayInput.value = '';
                updateWordCount();
                resultsPanel.style.display = 'none';
                lastResult = null;
                aiScoreValue.textContent = '—';
                aiScoreDetail.innerHTML =
                '点击上方按钮，使用 AI 模型评估作文<span>支持 OpenAI / Claude</span>';
